# RaspAP Docker env (from group_vars)
RASPAP_SSID={{ wifi_ssid }}
RASPAP_SSID_PASS={{ wifi_passphrase }}
RASPAP_COUNTRY={{ wifi_country | default('US') }}
RASPAP_WEBGUI_USER={{ raspap_webgui_user | default('admin') }}
RASPAP_WEBGUI_PASS={{ raspap_webgui_pass | default('secret') }}
RASPAP_WEBGUI_PORT={{ raspap_webgui_port | default('80') }}
