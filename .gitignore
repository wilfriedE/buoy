# Python-generated files
__pycache__/
*.py[oc]
dist/
wheels/
*.egg-info

# Build outputs (SD image, ROS tar, Pi Imager manifest)
build/
*.rpi-imager-manifest
*.tar
image/*.tar

# Virtual environments
.venv

# Images (downloaded RPi OS base, built SD images)
*.img
*.img.xz
image/base/

# Node
node_modules/

# Security: local overrides with real credentials
ansible/group_vars/*_local.yml
ansible/group_vars/*_secrets.yml
ansible/group_vars/vault.yml
ansible/.vault_pass
ansible/.vault_pass.*

# Security: environment files
.env
.env.*
!.env.example

# Security: private keys and certificates
*.pem
*.key
!*.pub
id_rsa
id_ed25519